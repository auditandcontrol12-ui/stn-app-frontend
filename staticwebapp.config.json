{
  "routes": [
    {
      "route": "/dashboard.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/stn-entry.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/stn-preview.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/stn-success.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/no-access.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/login",
      "rewrite": "/.auth/login/aad"
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout"
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/login"
    }
  },
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/*.css", "/*.js"]
  }
}