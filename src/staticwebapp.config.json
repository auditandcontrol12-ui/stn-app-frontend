{
  "routes": [
    {
      "route": "/dashboard.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/stn-entry.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/stn-preview.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/stn-success.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/no-access.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/login",
      "redirect": "/.auth/login/aad"
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout"
    },
    {
      "route": "/index.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/",
      "allowedRoles": ["anonymous"]
    }
  ],
  "responseOverrides": {
    "401": {
      "statusCode": 302,
      "redirect": "/.auth/login/aad?post_login_redirect_uri=/dashboard.html"
    }
  },
  
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/api/*",
      "/.auth/*",
      "/*.css",
      "/*.js",
      "/*.png",
      "/*.jpg",
      "/*.svg",
      "/*.ico"
    ]
  }
}